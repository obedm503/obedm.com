              class="mr-2 h-[1em] w-[1em]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
              />
            </svg>
            Source
          </ExternalLink>
        </div>
      ) : null
    } -->

    <p class="font-sans text-xs">
      {description}
    </p>

    <!-- <div class="mt-1">
      {
        languages.map(l => (
          <span class="mr-2 flex items-center text-xs">
            <svg
              style={`color: ${l.color}`}
              height="16"
              width="16"
              viewBox="0 0 16 16"
