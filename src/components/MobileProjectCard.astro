---
import { Image } from "astro:assets";

type Props = {
  title: string;
  url?: string;
  repo?: string;
  path?: string;
  image: ImageMetadata;
  description: string;
  languages?: Array<{ color: string; name: string }>;
  spotlight?: boolean;
};

const {
  title,
  url,
  path,
  repo,
  image,
  description,
  languages = [],
  spotlight,
} = Astro.props;
const href = path || url || repo;
---

<a
  href={href || "#"}
  target={href ? "_blank" : undefined}
  rel={href ? "noopener noreferrer" : undefined}
  class:list={[
    "bg-card col-span-3 flex items-center gap-3 overflow-hidden rounded-lg p-3 shadow-md transition duration-500 ease-in-out md:hidden",
    spotlight && "border-primary border-2",
  ]}
>
  <Image
    src={image}
    alt={title}
    class="w-14 shrink-0 object-cover"
    transition:name="image"
  />

  <div class="min-w-0 flex-1">
    <h2 class="text-sm font-semibold whitespace-nowrap">
      {title}
    </h2>

    <!-- {
      repo ? (
        <div class="text-md justify-start py-1">
